class Solution:
    def moveZeroes(self, nums):
        j = 0
        
        # First pass: place non-zeros
        for i in range(len(nums)):
            if nums[i] != 0:
                nums[j] = nums[i]
                j += 1
        
        # Second pass: fill zeros
        for i in range(j, len(nums)):
            nums[i] = 0
