import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner sc=new Scanner(System.in);

        String name=sc.nextLine();

        for(int i=0;i<name.length();i++){

            char ch=name.charAt(i);

            if(ch=='a'){
                System.out.print('o');
            }
            else{
                System.out.print(ch);
            }

        }

    }
}
